root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
# Markdown uses two trailing spaces to indicate a hard line break.
trim_trailing_whitespace = false

[*.{json,yaml,yml,toml,js,ts,tsx,jsx}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{png,jpg,jpeg,gif,ico,pdf,docx}]
# Binary - never touched by editor whitespace settings.
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
